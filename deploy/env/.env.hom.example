# GovBI IA — homologação (copie para .env.hom e preencha os secrets)
SPRING_PROFILES_ACTIVE=hom
GOVBI_AMBIENTE=hom
GOVBI_VERSAO=1.0.1
GOVBI_OIDC_HABILITADO=true
GOVBI_OIDC_ISSUER_URI=https://login.example.com/realms/govbi
GOVBI_OIDC_JWK_SET_URI=https://login.example.com/realms/govbi/protocol/openid-connect/certs
GOVBI_IA_MODO=gemini
GOVBI_GEMINI_API_KEY=
GOVBI_GEMINI_MODEL=gemini-2.0-flash
GOVBI_DADOS_EXECUTOR=sqlserver
GOVBI_DADOS_PERMITIR_EXECUCAO_REAL=false
GOVBI_SQLSERVER_URL=jdbc:sqlserver://host:1433;databaseName=govbi;encrypt=true;trustServerCertificate=true
GOVBI_SQLSERVER_USER=
GOVBI_SQLSERVER_PASSWORD=
GOVBI_PERSISTENCIA_OPERACIONAL_TIPO=sqlserver
GOVBI_OPERACIONAL_SQLSERVER_URL=jdbc:sqlserver://host:1433;databaseName=govbi_operacional;encrypt=true;trustServerCertificate=true
GOVBI_OPERACIONAL_SQLSERVER_USER=
GOVBI_OPERACIONAL_SQLSERVER_PASSWORD=
GOVBI_LOCK_TIPO=sqlserver
GOVBI_WORKER_HABILITADO=true
GOVBI_COFRE_HABILITADO=false
GOVBI_SEGURANCA_RATE_LIMIT_HABILITADO=true
GOVBI_SEGURANCA_RATE_LIMIT_REQUISICOES_POR_MINUTO=60
