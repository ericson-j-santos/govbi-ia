# =====================================================================
# GovBI IA — Variáveis de Ambiente para Homologação (v1.0.1)
# =====================================================================
# Copie este arquivo para .env.hom e preencha os valores reais.
# NUNCA commite o arquivo .env.hom com credenciais reais.
# =====================================================================

# --- Versão e Ambiente ---
GOVBI_VERSAO=1.0.1
GOVBI_AMBIENTE=homologacao

# --- Segurança / OIDC ---
GOVBI_OIDC_HABILITADO=true
GOVBI_OIDC_ISSUER_URI=https://seu-idp.empresa.com.br/realms/govbi-hom
GOVBI_OIDC_JWK_SET_URI=https://seu-idp.empresa.com.br/realms/govbi-hom/protocol/openid-connect/certs
GOVBI_OIDC_CLAIM_USUARIO=preferred_username
GOVBI_OIDC_CLAIM_PERFIS=roles
GOVBI_OIDC_CLAIM_UNIDADE=escopo_unidade

# --- Motor de IA ---
# Opções: mock-rag | openai | azure-openai | groq | gemini
GOVBI_IA_MODO=mock-rag
GOVBI_IA_MAX_TENTATIVAS=3

# OpenAI (preencha se GOVBI_IA_MODO=openai)
GOVBI_OPENAI_API_KEY=
GOVBI_OPENAI_MODEL=gpt-4.1-mini
GOVBI_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
GOVBI_OPENAI_TIMEOUT_SEGUNDOS=30

# Azure OpenAI (preencha se GOVBI_IA_MODO=azure-openai)
GOVBI_AZURE_OPENAI_ENDPOINT=
GOVBI_AZURE_OPENAI_DEPLOYMENT=
GOVBI_AZURE_OPENAI_API_KEY=
GOVBI_AZURE_OPENAI_API_VERSION=2025-01-01-preview
GOVBI_AZURE_OPENAI_TIMEOUT_SEGUNDOS=30

# Groq (preencha se GOVBI_IA_MODO=groq)
GOVBI_GROQ_API_KEY=
GOVBI_GROQ_MODEL=llama-3.3-70b-versatile
GOVBI_GROQ_TIMEOUT_SEGUNDOS=30

# --- Banco de Dados Analítico ---
# Opções: mock | sqlserver | databricks | postgres
GOVBI_DADOS_EXECUTOR=sqlserver
GOVBI_DADOS_PERMITIR_EXECUCAO_REAL=false
GOVBI_DADOS_QUERY_TIMEOUT_SEGUNDOS=30
GOVBI_DADOS_LIMITE_LINHAS_RETORNO=1000
GOVBI_DADOS_BLOQUEAR_SEM_FILTRO_TEMPORAL=true

# SQL Server Analítico
GOVBI_SQLSERVER_URL=jdbc:sqlserver://hom-sqlserver.empresa.com.br:1433;databaseName=govbi_gold_hom;encrypt=true;trustServerCertificate=false
GOVBI_SQLSERVER_USER=govbi_hom_ro
GOVBI_SQLSERVER_PASSWORD=ALTERE_A_SENHA
GOVBI_SQLSERVER_SCHEMA=gold

# --- Banco de Dados Operacional ---
GOVBI_PERSISTENCIA_OPERACIONAL_TIPO=sqlserver
GOVBI_OPERACIONAL_SQLSERVER_URL=jdbc:sqlserver://hom-sqlserver.empresa.com.br:1433;databaseName=govbi_operacional_hom;encrypt=true;trustServerCertificate=false
GOVBI_OPERACIONAL_SQLSERVER_USER=govbi_hom_op
GOVBI_OPERACIONAL_SQLSERVER_PASSWORD=ALTERE_A_SENHA
GOVBI_OPERACIONAL_SQLSERVER_SCHEMA=govbi

# --- Workers e Filas ---
GOVBI_WORKER_HABILITADO=false
GOVBI_FILA_HABILITADA=true
GOVBI_FILA_MODO=sincrona-controlada

# --- Notificações ---
GOVBI_NOTIFICACAO_HABILITADA=true
GOVBI_NOTIFICACAO_CANAIS=LOG
GOVBI_TEAMS_HABILITADO=false
GOVBI_TEAMS_WEBHOOK_URL=
GOVBI_EMAIL_HABILITADO=false
GOVBI_EMAIL_REMETENTE=govbi-hom@empresa.com.br

# --- Observabilidade ---
GOVBI_OBSERVABILIDADE_METRICAS_HABILITADAS=true
GOVBI_OBSERVABILIDADE_TRACING_HABILITADO=true
GOVBI_OTLP_TRACING_ENDPOINT=http://otel-collector-hom.empresa.com.br:4318/v1/traces
GOVBI_TRACING_SAMPLING_PROBABILITY=0.25

# --- Release / Homologação ---
GOVBI_RELEASE_MODO=homologacao
GOVBI_RELEASE_HARDENING_OBRIGATORIO=true
GOVBI_RELEASE_EXIGIR_OIDC_PRODUCAO=true

# --- Cofre de Segredos (opcional) ---
GOVBI_COFRE_HABILITADO=false
GOVBI_COFRE_URL=
GOVBI_COFRE_TOKEN=
