# =====================================================================
# GovBI IA — Variáveis de Ambiente para Produção (v1.0.1)
# =====================================================================
# Copie este arquivo para .env.prod e preencha os valores reais.
# NUNCA commite o arquivo .env.prod com credenciais reais.
# Gerencie este arquivo via cofre corporativo (Vault, Azure Key Vault,
# AWS Secrets Manager, etc.).
# =====================================================================

# --- Versão e Ambiente ---
GOVBI_VERSAO=1.0.1
GOVBI_AMBIENTE=producao

# --- Segurança / OIDC (OBRIGATÓRIO em produção) ---
GOVBI_OIDC_HABILITADO=true
GOVBI_OIDC_ISSUER_URI=https://seu-idp.empresa.com.br/realms/govbi-prod
GOVBI_OIDC_JWK_SET_URI=https://seu-idp.empresa.com.br/realms/govbi-prod/protocol/openid-connect/certs
GOVBI_OIDC_CLAIM_USUARIO=preferred_username
GOVBI_OIDC_CLAIM_PERFIS=roles
GOVBI_OIDC_CLAIM_UNIDADE=escopo_unidade

# --- Motor de IA ---
# Opções: openai | azure-openai | groq | gemini
# ATENÇÃO: NÃO use mock-rag em produção
GOVBI_IA_MODO=azure-openai
GOVBI_IA_MAX_TENTATIVAS=3

# OpenAI (preencha se GOVBI_IA_MODO=openai)
GOVBI_OPENAI_API_KEY=
GOVBI_OPENAI_MODEL=gpt-4.1-mini
GOVBI_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
GOVBI_OPENAI_TIMEOUT_SEGUNDOS=30

# Azure OpenAI (preencha se GOVBI_IA_MODO=azure-openai)
GOVBI_AZURE_OPENAI_ENDPOINT=https://govbi-openai.openai.azure.com
GOVBI_AZURE_OPENAI_DEPLOYMENT=gpt-4
GOVBI_AZURE_OPENAI_API_KEY=GERENCIE_VIA_COFRE
GOVBI_AZURE_OPENAI_API_VERSION=2025-01-01-preview
GOVBI_AZURE_OPENAI_TIMEOUT_SEGUNDOS=30

# Groq (preencha se GOVBI_IA_MODO=groq)
GOVBI_GROQ_API_KEY=
GOVBI_GROQ_MODEL=llama-3.3-70b-versatile
GOVBI_GROQ_TIMEOUT_SEGUNDOS=30

# --- Banco de Dados Analítico (OBRIGATÓRIO em produção) ---
# ATENÇÃO: NÃO use mock em produção
GOVBI_DADOS_EXECUTOR=sqlserver
GOVBI_DADOS_PERMITIR_EXECUCAO_REAL=true
GOVBI_DADOS_QUERY_TIMEOUT_SEGUNDOS=30
GOVBI_DADOS_LIMITE_LINHAS_RETORNO=1000
GOVBI_DADOS_BLOQUEAR_SEM_FILTRO_TEMPORAL=true
GOVBI_DADOS_FETCH_SIZE=250

# SQL Server Analítico
GOVBI_SQLSERVER_URL=jdbc:sqlserver://prod-sqlserver.empresa.com.br:1433;databaseName=govbi_gold;encrypt=true;trustServerCertificate=false
GOVBI_SQLSERVER_USER=govbi_prod_ro
GOVBI_SQLSERVER_PASSWORD=GERENCIE_VIA_COFRE
GOVBI_SQLSERVER_SCHEMA=gold

# --- Banco de Dados Operacional (OBRIGATÓRIO em produção) ---
GOVBI_PERSISTENCIA_OPERACIONAL_TIPO=sqlserver
GOVBI_OPERACIONAL_SQLSERVER_URL=jdbc:sqlserver://prod-sqlserver.empresa.com.br:1433;databaseName=govbi_operacional;encrypt=true;trustServerCertificate=false
GOVBI_OPERACIONAL_SQLSERVER_USER=govbi_prod_op
GOVBI_OPERACIONAL_SQLSERVER_PASSWORD=GERENCIE_VIA_COFRE
GOVBI_OPERACIONAL_SQLSERVER_SCHEMA=govbi

# --- Workers e Filas ---
GOVBI_WORKER_HABILITADO=true
GOVBI_WORKER_INTERVALO_MS=30000
GOVBI_WORKER_LOTE=5
GOVBI_FILA_HABILITADA=true
GOVBI_FILA_MODO=sincrona-controlada

# --- Aprovações e SLA ---
GOVBI_APROVACAO_HABILITADA=true
GOVBI_APROVACAO_SLA_HORAS=24
GOVBI_SLA_EXPIRAR_APROVACOES_HABILITADO=true

# --- Notificações ---
GOVBI_NOTIFICACAO_HABILITADA=true
GOVBI_NOTIFICACAO_CANAIS=LOG,EMAIL
GOVBI_TEAMS_HABILITADO=true
GOVBI_TEAMS_WEBHOOK_URL=https://empresa.webhook.office.com/webhookb2/PREENCHA
GOVBI_EMAIL_HABILITADO=true
GOVBI_EMAIL_REMETENTE=govbi@empresa.com.br

# --- Exportação e Download ---
GOVBI_EXPORTACAO_FORMATOS=csv,json
GOVBI_EXPORTACAO_LIMITE_LINHAS=5000
GOVBI_DOWNLOAD_HABILITADO=true
GOVBI_DOWNLOAD_EXIGIR_AUDITORIA=true

# --- DLQ ---
GOVBI_DLQ_HABILITADA=true
GOVBI_DLQ_MAX_TENTATIVAS=3

# --- Lock Distribuído ---
GOVBI_LOCK_TIPO=sqlserver
GOVBI_LOCK_TTL_SEGUNDOS=120

# --- Observabilidade ---
GOVBI_OBSERVABILIDADE_METRICAS_HABILITADAS=true
GOVBI_OBSERVABILIDADE_TRACING_HABILITADO=true
GOVBI_OTLP_TRACING_ENDPOINT=http://otel-collector.empresa.com.br:4318/v1/traces
GOVBI_TRACING_SAMPLING_PROBABILITY=0.10

# --- Release / Produção ---
GOVBI_RELEASE_MODO=producao
GOVBI_RELEASE_HARDENING_OBRIGATORIO=true
GOVBI_RELEASE_EXIGIR_OIDC_PRODUCAO=true
GOVBI_RELEASE_EXIGIR_SQLSERVER_OPERACIONAL_PRODUCAO=true
GOVBI_RELEASE_EXIGIR_EXECUCAO_REAL_EXPLICITA=true
GOVBI_RELEASE_EXIGIR_DOWNLOAD_AUDITADO=true

# --- Cofre de Segredos (RECOMENDADO em produção) ---
GOVBI_COFRE_HABILITADO=true
GOVBI_COFRE_URL=https://cofre.empresa.com.br
GOVBI_COFRE_TOKEN=GERENCIE_VIA_CI_CD

# --- Homologação ---
GOVBI_HOMOLOGACAO_EXIGIR_SMOKE_TESTS=true
GOVBI_HOMOLOGACAO_EXIGIR_ACEITE_FORMAL=true
GOVBI_HOMOLOGACAO_BLOQUEAR_PROMOCAO_SEM_READINESS=true
