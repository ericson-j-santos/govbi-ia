# GovBI IA — Produção
# Template sem segredos. Substitua placeholders no cofre/secret manager do ambiente.

SPRING_PROFILES_ACTIVE=prod
GOVBI_RELEASE_MODO=producao
GOVBI_OIDC_HABILITADO=true
GOVBI_PERSISTENCIA_OPERACIONAL_TIPO=sqlserver
GOVBI_DADOS_EXECUTOR=sqlserver
GOVBI_DADOS_PERMITIR_EXECUCAO_REAL=true
GOVBI_LOCK_TIPO=sqlserver
GOVBI_WORKER_HABILITADO=true
GOVBI_DOWNLOAD_HABILITADO=true
GOVBI_NOTIFICACAO_CANAIS_ATIVOS=LOG,TEAMS,EMAIL

# Conectividade — preencher via secret manager
SPRING_DATASOURCE_URL=jdbc:sqlserver://<sqlserver-host>:1433;databaseName=<database>;encrypt=true;trustServerCertificate=false
SPRING_DATASOURCE_USERNAME=<secret:sqlserver-username>
SPRING_DATASOURCE_PASSWORD=<secret:sqlserver-password>
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=https://<tenant-or-idp>/.well-known/jwks.json
